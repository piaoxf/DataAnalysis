   "source": [
    "import scipy\n",
    "\n",
    "n = 31000\n",
    "p = 0.00203\n",
    "k = 63\n",
    "\n",
    "# comb\n",
    "bi_coef = scipy.special.comb(31000,63)\n",
    "probability = bi_coef * (p**k) * ((1-p)**(n-k))\n",
    "print(probability)\n"
   ]
  }
 ],
